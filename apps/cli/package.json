{
  "name": "@exit-zero-labs/runmark",
  "version": "0.4.0",
  "description": "runmark CLI and MCP server. `runmark` for humans and scripts, `runmark mcp` for agents.",
  "type": "module",
  "license": "MIT",
  "author": "Exit Zero Labs LLC",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "runmark": "dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./testing": {
      "default": "./testing.js"
    }
  },
  "files": [
    "dist",
    "src",
    "testing.js"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/exit-zero-labs/runmark.git",
    "directory": "apps/cli"
  },
  "bugs": {
    "url": "https://github.com/exit-zero-labs/runmark/issues"
  },
  "homepage": "https://github.com/exit-zero-labs/runmark#readme",
  "funding": [
    {
      "type": "github",
      "url": "https://github.com/sponsors/exit-zero-labs"
    },
    {
      "type": "opencollective",
      "url": "https://opencollective.com/exit-zero-labs"
    }
  ],
  "publishConfig": {
    "access": "public",
    "directory": "publish"
  },
  "scripts": {
    "build": "pnpm exec tsc -p tsconfig.json && node ../../scripts/build-published-app.mjs apps/cli",
    "typecheck": "pnpm exec tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@exit-zero-labs/runmark-contracts": "workspace:*",
    "@exit-zero-labs/runmark-execution": "workspace:*",
    "@exit-zero-labs/runmark-shared": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  }
}
