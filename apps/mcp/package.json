{
  "name": "@exit-zero-labs/httpi-mcp",
  "version": "0.1.1",
  "description": "MCP entrypoint for httpi.",
  "type": "module",
  "license": "MIT",
  "author": "Exit Zero Labs LLC",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "httpi-mcp": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/exit-zero-labs/httpi.git",
    "directory": "apps/mcp"
  },
  "bugs": {
    "url": "https://github.com/exit-zero-labs/httpi/issues"
  },
  "homepage": "https://github.com/exit-zero-labs/httpi#readme",
  "publishConfig": {
    "access": "public",
    "directory": "publish"
  },
  "scripts": {
    "build": "pnpm exec tsc -p tsconfig.json && node ../../scripts/build-published-app.mjs apps/mcp",
    "typecheck": "pnpm exec tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@exit-zero-labs/httpi-execution": "workspace:*",
    "@exit-zero-labs/httpi-shared": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  }
}
