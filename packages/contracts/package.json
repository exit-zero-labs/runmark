{
  "name": "@exit-zero-labs/runmark-contracts",
  "private": true,
  "version": "0.3.0",
  "description": "Shared contracts for runmark.",
  "type": "module",
  "license": "MIT",
  "author": "Exit Zero Labs LLC",
  "engines": {
    "node": ">=20"
  },
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./schemas/config.schema.json": "./schemas/config.schema.json",
    "./schemas/env.schema.json": "./schemas/env.schema.json",
    "./schemas/header-block.schema.json": "./schemas/header-block.schema.json",
    "./schemas/auth-block.schema.json": "./schemas/auth-block.schema.json",
    "./schemas/request.schema.json": "./schemas/request.schema.json",
    "./schemas/run.schema.json": "./schemas/run.schema.json"
  },
  "files": [
    "dist",
    "src",
    "schemas"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/exit-zero-labs/runmark.git",
    "directory": "packages/contracts"
  },
  "bugs": {
    "url": "https://github.com/exit-zero-labs/runmark/issues"
  },
  "homepage": "https://github.com/exit-zero-labs/runmark#readme",
  "scripts": {
    "build": "pnpm exec tsc -p tsconfig.json",
    "typecheck": "pnpm exec tsc -p tsconfig.json --noEmit"
  }
}
