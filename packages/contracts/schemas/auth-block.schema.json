{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/exit-zero-labs/runmark/main/packages/contracts/schemas/auth-block.schema.json",
  "title": "runmark auth block",
  "type": "object",
  "additionalProperties": false,
  "required": ["auth"],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "title": {
      "type": "string"
    },
    "auth": {
      "$ref": "#/$defs/authDefinition"
    }
  },
  "$defs": {
    "authDefinition": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["scheme", "token"],
          "properties": {
            "scheme": {
              "const": "bearer"
            },
            "token": {
              "type": "string"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["scheme", "username", "password"],
          "properties": {
            "scheme": {
              "const": "basic"
            },
            "username": {
              "type": "string"
            },
            "password": {
              "type": "string"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["scheme", "header", "value"],
          "properties": {
            "scheme": {
              "const": "header"
            },
            "header": {
              "type": "string"
            },
            "value": {
              "type": "string"
            }
          }
        }
      ]
    }
  }
}
