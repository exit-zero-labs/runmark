{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/exit-zero-labs/runmark/main/packages/contracts/schemas/config.schema.json",
  "title": "runmark project config",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "project", "defaults"],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "project": {
      "type": "string",
      "minLength": 1
    },
    "defaultEnv": {
      "type": "string",
      "minLength": 1
    },
    "defaults": {
      "$ref": "#/$defs/flatVariableMap"
    },
    "capture": {
      "$ref": "#/$defs/capturePolicy"
    }
  },
  "$defs": {
    "flatValue": {
      "type": ["string", "number", "boolean", "null"]
    },
    "flatVariableMap": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/flatValue"
      }
    },
    "capturePolicy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "requestSummary": {
          "type": "boolean"
        },
        "responseMetadata": {
          "type": "boolean"
        },
        "responseBody": {
          "enum": ["full", "metadata", "none"]
        },
        "maxBodyBytes": {
          "type": "number",
          "minimum": 0
        },
        "redactHeaders": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
