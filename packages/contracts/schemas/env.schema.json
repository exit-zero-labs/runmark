{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/exit-zero-labs/runmark/main/packages/contracts/schemas/env.schema.json",
  "title": "runmark environment definition",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "values"],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "title": {
      "type": "string"
    },
    "values": {
      "$ref": "#/$defs/flatVariableMap"
    }
  },
  "$defs": {
    "flatValue": {
      "type": ["string", "number", "boolean", "null"]
    },
    "flatVariableMap": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/flatValue"
      }
    }
  }
}
