{
  "name": "@exit-zero-labs/runmark-execution",
  "private": true,
  "version": "0.3.0",
  "description": "Execution orchestration for runmark.",
  "type": "module",
  "license": "MIT",
  "author": "Exit Zero Labs LLC",
  "engines": {
    "node": ">=20"
  },
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./testing": {
      "types": "./src/internal/testing.ts",
      "default": "./testing.js"
    }
  },
  "files": [
    "dist",
    "src",
    "testing.js"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/exit-zero-labs/runmark.git",
    "directory": "packages/execution"
  },
  "bugs": {
    "url": "https://github.com/exit-zero-labs/runmark/issues"
  },
  "homepage": "https://github.com/exit-zero-labs/runmark#readme",
  "scripts": {
    "build": "pnpm exec tsc -p tsconfig.json",
    "typecheck": "pnpm exec tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@exit-zero-labs/runmark-contracts": "workspace:*",
    "@exit-zero-labs/runmark-definitions": "workspace:*",
    "@exit-zero-labs/runmark-http": "workspace:*",
    "@exit-zero-labs/runmark-runtime": "workspace:*",
    "@exit-zero-labs/runmark-shared": "workspace:*"
  }
}
