{
  "name": "@exit-zero-labs/httpi-definitions",
  "private": true,
  "version": "0.1.0",
  "description": "Definition loading and validation for httpi.",
  "type": "module",
  "license": "MIT",
  "author": "Exit Zero Labs LLC",
  "engines": {
    "node": ">=20"
  },
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/exit-zero-labs/httpi.git",
    "directory": "packages/definitions"
  },
  "bugs": {
    "url": "https://github.com/exit-zero-labs/httpi/issues"
  },
  "homepage": "https://github.com/exit-zero-labs/httpi#readme",
  "scripts": {
    "build": "pnpm exec tsc -p tsconfig.json",
    "typecheck": "pnpm exec tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@exit-zero-labs/httpi-contracts": "workspace:*",
    "@exit-zero-labs/httpi-shared": "workspace:*",
    "yaml": "^2.8.3"
  }
}
